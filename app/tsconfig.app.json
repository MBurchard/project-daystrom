{
  "extends": ["../tsconfig.base.json", "@vue/tsconfig/tsconfig.dom.json"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@app/*": ["modules/app/src/*"],
      "@generated/*": ["modules/app/src/generated/*"],
      "@resources/*": ["resources/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "modules/app/src/**/*.ts",
    "modules/app/src/**/*.vue"
  ],
  "exclude": [
    "**/__tests__/**/*.spec.ts"
  ]
}
